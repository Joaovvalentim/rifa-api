generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  orders Order[]
}

model Raffle {
  id             String   @id @default(cuid())
  title          String
  description    String?
  minNumber      Int      @default(1)
  maxNumber      Int
  pricePerNumber Int
  status         String   @default("active") // draft | active | finished
  createdAt      DateTime @default(now())

  imageUrl       String?
  videoUrl       String?
  images         String[] @default([])

  orders       Order[]
  orderNumbers OrderNumber[]

  winner Winner?

  @@index([status])
}

model Order {
  id                     String    @id @default(cuid())
  userId                 String
  raffleId               String
  quantity               Int
  status                 String    @default("pending") // pending | paid | expired | cancelled | failed
  totalAmount            Int
  paymentProvider        String    @default("mercado_pago")
  paymentStatus          String    @default("pending")
  paymentStatusDetail    String?
  paymentExternalRef     String    @unique
  paymentProviderOrderId String?   @unique
  paymentProviderTxnId   String?
  paymentTicketUrl       String?
  paymentQrCode          String?
  paymentQrCodeBase64    String?
  expiresAt              DateTime?
  paidAt                 DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user    User          @relation(fields: [userId], references: [id])
  raffle  Raffle        @relation(fields: [raffleId], references: [id])
  numbers OrderNumber[]

  winner Winner?

  @@index([userId])
  @@index([raffleId])
  @@index([status, expiresAt])
  @@index([raffleId, status])
}

model OrderNumber {
  id        String   @id @default(cuid())
  orderId   String
  raffleId  String
  number    Int
  status    String   @default("reserved") // reserved | confirmed
  createdAt DateTime @default(now())

  order  Order  @relation(fields: [orderId], references: [id])
  raffle Raffle @relation(fields: [raffleId], references: [id])

  @@unique([raffleId, number])
  @@index([orderId])
  @@index([raffleId, status])
}

model Winner {
  id        String   @id @default(cuid())
  raffleId  String   @unique
  orderId   String   @unique
  number    Int
  seed      String
  createdAt DateTime @default(now())

  raffle Raffle @relation(fields: [raffleId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id])
}
